# =============================================
# Telegram Swap Bot — Environment Variables
# =============================================
# Copia este archivo a .env y completa los valores
#   cp .env-sample .env

# --- REQUERIDO ---
# Token del bot de Telegram (obténlo de @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# --- REQUERIDO ---
# IDs de administradores (separados por coma)
# Obtén tu ID de @userinfobot en Telegram
ADMIN_IDS=123456789

# --- MongoDB ---
# Opción A: MongoDB local (Docker)
MONGO_URI=mongodb://mongo:27017/telegram-swap-bot

# Opción B: MongoDB Atlas (nube gratuita)
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/telegram-swap-bot?retryWrites=true&w=majority

# --- Boltz API ---
BOLTZ_API_URL=https://api.boltz.exchange

# Boltz Pro (default: on). Set to "false" to disable.
# Boltz Pro da 0% o fees negativos cuando la liquidez esta desbalanceada.
BOLTZ_PRO_ENABLED=true

# --- ChangeNOW API (para USDT/USDC swaps) ---
# Registrate en https://changenow.io/affiliate
CHANGENOW_API_KEY=

# --- Bot Config ---
# Comisión inicial (1.5 a 2.5%)
COMMISSION_RATE=2.5

# Nivel de logs: debug, info, warn, error
LOG_LEVEL=info

# Zona horaria
TZ=UTC

# --- Wallet — Donde llegan las ganancias (SOLO BTC/Lightning) ---
# Dirección Lightning (ej: tuusuario@getalby.com)
# Crea una gratis en https://getalby.com
WALLET_LIGHTNING_ADDRESS=

# Dirección BTC on-chain (respaldo si no hay Lightning)
WALLET_BTC_ADDRESS=
